# Metrify provider credentials
METRIFY_PROVIDER_KEY=pk_live_...
METRIFY_GATEWAY_URL=https://airy-wholeness-production-fcc4.up.railway.app

# JWT / OAuth Bearer auth (RS256 — no shared secret needed)
# METRIFY_BACKEND_URL: fetch JWKS public key + listed as authorization_server in RFC 9728 metadata
# MCP_BASE_URL: public URL of THIS server, used to build the protected-resource metadata
METRIFY_BACKEND_URL=https://airy-wholeness-production-fcc4.up.railway.app
MCP_BASE_URL=https://web-production-b51ff.up.railway.app
JWT_ISSUER=metrify-backend

# Upstream API keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
STABILITY_API_KEY=...
ASSEMBLYAI_API_KEY=...
APIFY_API_KEY=...
FIRECRAWL_API_KEY=...

# Server
PORT=8000
